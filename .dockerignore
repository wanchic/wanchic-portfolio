# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Ignore git directory.
/.git
/.gitattributes
/.gitignore
/lefthook.yml

# Version Managers -  rvm, nvm, asdf
/.ruby-version
/.ruby-gemset
/.nvmrc
/.tool-versions

# IDEs - Ruby-mine
/.idea*

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Rspec Tests & Coverage
/test

# Linting
/.rspec
/.mdlrc
/.rubocop.yml
/.stylelintrc.json
/.yamllint.yml
/eslint.config.mjs
/md_styles.rb

# Documents
/README*
/Changelog*

# Ignore master key(s) for decrypting credentials and more.
/config/credentials/*.yml.enc*
!/config/credentials/production.yml.enc
/config/credentials/*.key
/config/*.yml.enc*
/config/*.key

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore assets.
/node_modules
/app/assets/builds/*
!/app/assets/builds/.keep

# Public
/public/assets

# Ignore CI service files.
/.github

# Ignore Kamal files.
/config/deploy*.yml
/.kamal

# Ignore development files
/.devcontainer

# Ignore Docker-related files
/.docker-cache
